YOUTUBE_API_KEY=

# Use one of these for Google Sheets auth.
GOOGLE_SERVICE_ACCOUNT_FILE=
GOOGLE_SERVICE_ACCOUNT_JSON=

# Optional. If empty, the script creates a new Google Sheet.
GOOGLE_SPREADSHEET_ID=

# Optional. If provided, the created spreadsheet is shared with this email.
GOOGLE_SHARE_WITH_EMAIL=

# Optional.
GOOGLE_SPREADSHEET_TITLE=Thalapathy Vijay YouTube Daily Monitor
REPORT_TIMEZONE=Asia/Kolkata

# Optional deep audio mode for client-grade narrative reports.
# Use Gemini or OpenAI. This may cost money per video.
TRANSCRIPTION_PROVIDER=gemini
ANALYSIS_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
OPENAI_API_KEY=
OPENAI_ANALYSIS_MODEL=gpt-4o-mini
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
ENABLE_AUDIO_TRANSCRIPTION=false
REQUIRE_AUDIO_TRANSCRIPTION=false
AUDIO_MAX_FILESIZE_MB=24

# Optional. If empty, the analyzer uses a local rule-based sentiment scorer.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
