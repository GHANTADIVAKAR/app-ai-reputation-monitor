PORT=3000
SCAN_INTERVAL_HOURS=6

# Optional integrations. The app works in demo mode without these.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
LIVE_NEWS_ENABLED=true
SERPAPI_API_KEY=
YOUTUBE_API_KEY=
REDDIT_ENABLED=false
REDDIT_USER_AGENT=ReputationDashboard/0.1
X_BEARER_TOKEN=
INSTAGRAM_ACCESS_TOKEN=
SOCIAL_LISTENING_WEBHOOK_URL=
ALERT_WEBHOOK_URL=

# Comma-separated domains or RSS/search phrases you care about.
DEFAULT_QUERIES=latest news,interview,review,controversy,public reaction
